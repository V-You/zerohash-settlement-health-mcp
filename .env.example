# Data source: "mock" or "live"
ZEROHASH_DATA_SOURCE=mock

# Zero Hash CERT API (V2 — leave empty for V1)
ZEROHASH_API_KEY=
ZEROHASH_API_SECRET=
ZEROHASH_API_PASSPHRASE=
ZEROHASH_API_BASE_URL=https://api.cert.zerohash.com

# Logging
LOG_LEVEL=INFO

# Suppress requests library version-check warning (cosmetic; caused by mcp-cli deps)
PYTHONWARNINGS=ignore:::requests

# --- Market Prices (CoinGecko) ---
# Log API errors to market_errors.log (with timestamps) for downtime detection.
# Set to "true" to enable; default is "false" (errors only go to Python logging).
MARKET_PRICE_ERROR_LOG=false

# --- LLM Provider (for mcp-cli client — not used by the MCP server itself) ---
# Configure ONE of the following. Groq is recommended (free tier, very fast).
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
